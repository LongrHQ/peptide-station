{
  "name": "peptide-station",
  "version": "1.0.0",
  "private": true,
  "author": "LongrHQ",
  "scripts": {
    "clean": "pnpm -r run rimraf \"{.next,out,dist,build,node_modules}\" && rimraf node_modules",
    "dev": "pnpm --filter minimal dev",
    "build": "pnpm --filter minimal build",
    "start": "pnpm --filter minimal start",
    "type:check": "pnpm --filter minimal type:check",
    "lint": "pnpm --filter minimal lint",
    "dev:classic": "pnpm --filter classic dev",
    "dev:minimal": "pnpm --filter minimal dev",
    "dev:modern": "pnpm --filter modern dev",
    "build:classic": "pnpm --filter classic build",
    "build:minimal": "pnpm --filter minimal build",
    "build:modern": "pnpm --filter modern build"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "rimraf": "^6.1.3"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx,md,css}": [
      "prettier --trailing-comma es5 --single-quote --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": ["sharp", "core-js"]
  }
}
